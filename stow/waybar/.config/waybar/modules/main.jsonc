{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "show-special": true,
    "format": "{name}",
    "format-icons": {
      "urgent": "!",
      "active": "ŌŚÅ",
      "default": "ŌŚŗ"
    }
    // "persistent-workspaces": {
    //   "*": 5
    // }
  },

  // Taskbar - Lists open applications.
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "kitty", "ghostty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },

  // Hyprland window
  "hyprland/window": {
    "max-length": 60,
    "swap-icon-label": false,
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // Empty spacer
  "custom/empty": {
    "format": " ",
    "tooltip": false
  },

  // Tools
  "custom/tools": {
    "format": "’é«",
    "tooltip-format": "Tools"
  },

  // Cliphist
  "custom/cliphist": {
    "format": "’ā¬",
    "on-click": "sleep 0.1 && ~/.config/my/scripts/cliphist.sh",
    "on-click-right": "sleep 0.1 && ~/.config/my/scripts/cliphist.sh d",
    "on-click-middle": "sleep 0.1 && ~/.config/my/scripts/cliphist.sh w",
    "tooltip-format": "Left: Open clipboard Manager\nRight: Delete an entry\nMiddle: Clear list"
  },

  // Wallpaper
  "custom/wallpaper": {
    "format": "’ĆŠ",
    "on-click": "waypaper",
    "on-click-right": "~/.config/hypr/scripts/wallpaper-effect.sh",
    "tooltip-format": "Left: Select wallpaper\nRight: Select wallpaper effect"
  },

  // Settings
  "custom/settings": {
    "format": "’Ćō",
    "on-click": "sleep 0.1 && gnome-control-center",
    "tooltip-format": "Gnome Control Center"

    // "format": " ¾░Æō ",
    // "interval": "once",
    // "on-click": "~/.config/hypr/scripts/settings-menu.sh",
    // "tooltip": true,
    // "tooltip-format": "System Settings"
  },

  // Keybindings
  "custom/keybindings": {
    "format": "’ä£",
    "on-click": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip": false
  },

  // Filemanager Launcher
  "custom/filemanager": {
    "format": "’ü╗",
    "on-click": "~/.config/hypr/settings/filemanager.sh",
    "tooltip": false
  },

  // Browser Launcher
  "custom/browser": {
    "format": "’ŗÉ",
    "on-click": "~/.config/hypr/settings/browser.sh",
    "tooltip": false
  },

  // AI Launcher
  "custom/ai": {
    "format": "’Ģä",
    "on-click": "chromium --app=https://claude.ai/chat",
    "tooltip-format": "Open Claude"
  },

  // Calculator
  "custom/calculator": {
    "format": "’ć¼",
    "on-click": "qalculate-gtk",
    "tooltip-format": "Open calculator"
  },

  // Wofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": "Apps",
    // END APPS LABEL
    "on-click": "sleep 0.2;pkill wofi || wofi --show=drun",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Wofi Application Launcher, with icon
  "custom/appmenuicon": {
    "format": "’äĄ",
    "on-click": "sleep 0.2;wofi --show=drun",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Power Menu
  "custom/exit": {
    "format": "’Ćæ",
    "on-click": "~/.config/hypr/scripts/wlogout.sh",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },

  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "<span rise='8pt'>’éó<span foreground='red'><sup>’æä</sup></span></span>",
      "none": "’éó",
      "dnd-notification": "<span rise='8pt'>’éó<span foreground='red'><sup>’æä</sup></span></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "<span rise='8pt'>’éó<span foreground='red'><sup>’æä</sup></span></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "<span rise='8pt'>’ćĘ<span foreground='red'><sup>’æä</sup></span></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  // Hyprshade
  "custom/hyprshade": {
    "format": "Ņō£",
    "tooltip-format": "Left: Open hyprshade\nRight: Select hyprshade filter",
    "on-click": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh wofi"
  },

  // Hypridle inhibitor - Toggle hypridle
  "custom/hypridle": {
    "format": "’ĆŻ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle",
    "on-click-right": "hyprlock"
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "’ĆŻ",
      "unlocked": "’é£"
    }
  },

  // System tray
  "tray": {
    // "icon-size": 22,
    // "show-passive-items": true,
    // "spacing": 8

    "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    // "format": "<span foreground='#f5c2e7'>’ĆŚ   </span>{:%a %d %H:%M}",
    // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M %a}",
    "tooltip": false,
    // "timezone": "",
    "on-click": "sleep 0.1 && gnome-calendar"
  },

  // Hardware stats toggle (click to expand/collapse)
  "custom/hardware-toggle": {
    "exec": "~/.config/hypr/scripts/hardware-toggle.sh",
    "interval": 2,
    "return-type": "json",
    "on-click": "~/.config/hypr/scripts/hardware-toggle.sh toggle",
    "signal": 10
  },

  // System
  "custom/system": {
    "format": "’éĆ",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "format": "/ C {usage}% ",
    "tooltip-format": "CPU usage: {usage}%",
    "on-click": "~/.config/hypr/settings/system-monitor.sh"
  },

  // Memory
  "memory": {
    "format": "/ M {}% ",
    "tooltip-format": "Memory: {used:0.1f} GiB / {total:0.1f} GiB ({percentage}%)",
    "on-click": "~/.config/hypr/settings/system-monitor.sh"
  },

  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "tooltip-format": "Disk: {used} / {total} used ({percentage_used}%)",
    "path": "/",
    "on-click": "~/.config/hypr/settings/system-monitor.sh"
  },

  "hyprland/language": {
    "format": "/ K {short}",
    "tooltip-format": "Keyboard layout: {long}"
  },

  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/system", "disk", "cpu", "memory"]
  },

  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tools",
      "custom/cliphist",
      "custom/hypridle",
      "custom/hyprshade"
    ]
  },

  // Group Links
  "group/links": {
    "orientation": "horizontal",
    "modules": ["custom/ai"]
  },

  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": ["custom/settings", "custom/waybarthemes", "custom/wallpaper"]
  },

  // Network
  "network": {
    // "format-disabled": "<span size='13000' foreground='#f5e0dc'>  </span>Disabled",
    // "format-disconnected": "<span size='13000' foreground='#f5e0dc'>’ü¬  </span>Disconnected",
    // "format-ethernet": "<span size='13000' foreground='#f5e0dc'>¾░żŁ  </span>{ifname}",
    // "format-linked": "{ifname} (No IP) ’×¢",
    // "format-wifi": "<span size='13000' foreground='#f5e0dc'>’ć½  </span>{essid}",
    // "interface": "wlan0",
    // "interval": 5,
    // "on-click": "hyprctl keyword windowrulev2 'float,class:(com.mitchellh.ghostty),title:(NetworkManager)' && hyprctl keyword windowrulev2 'center,class:(com.mitchellh.ghostty),title:(NetworkManager)' && hyprctl keyword windowrulev2 'size 1100 700,class:(com.mitchellh.ghostty),title:(NetworkManager)' && ghostty --title='NetworkManager' -e ~/.config/hypr/scripts/nmtui-with-scan.sh && hyprctl keyword windowrulev2 'unset,class:(com.mitchellh.ghostty),title:(NetworkManager)' &",
    // "tooltip-format-ethernet": "{ifname}: {ipaddr}",
    // "tooltip-format-wifi": "Signal Strength: {signalStrength}% | {ipaddr}"

    "format": "{ifname}",
    "format-wifi": "’ć½  {essid} ({signalStrength}%)",
    "format-ethernet": "’×¢  {ifname}",
    "format-disconnected": "Disconnected !",
    "tooltip-format": "’×¢ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "’×¢ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/hypr/settings/networkmanager.sh"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "’Ś¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
    "tooltip-format": "{time}",

    // "format": "<span size='13000' foreground='#a6e3a1'>{icon} </span> {capacity}%",
    // "format-alt": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {time}",
    // "format-charging": "<span size='13000' foreground='#B1E3AD'>’ć” </span>{capacity}%",
    // "format-critical": "<span size='13000' foreground='#E38C8F'>{icon} </span> {capacity}%",
    // "format-full": "<span size='13000' foreground='#B1E3AD'>’Ćä </span>{capacity}%",
    // "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
    // "format-plugged": "<span size='13000' foreground='#B1E3AD'>’ć” </span>{capacity}%",
    // "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {capacity}%",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },

  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’åģ",
      "performance": "’ā¦",
      "balanced": "’ĪŻ",
      "power-saver": "’ü¼"
    }
  },

  // Power Profiles (tuned-ppd)
  "custom/power-profiles": {
    "exec": "~/.config/hypr/scripts/power-profiles.sh",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "on-click": "~/.config/hypr/scripts/power-profiles.sh toggle",
    "tooltip": true
  },

  // Pulseaudio
  "pulseaudio": {
    // "format": "{icon}  {volume}%",
    // "format-icons": {
    //   "default": ["’Ć”", "’Ć¦", "’Ć© "]
    // },
    // "format-muted": "’æ”",
    // "on-click": "pavucontrol"

    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}¾░é▓ {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}¾░é▓ {format_source}",
    "format-muted": "’Ü® {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["’Ć”", "’Ć©", "’Ć©"]
    },
    "on-click": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "<span size='115%'>’Ŗō</span>  {status}",
    "format-disabled": "<span size='115%'>¾░é▓</span>",
    "format-off": "<span size='115%'>¾░é▓</span>",
    "format-no-controller": "<span size='115%'>¾░é▓</span>",
    "format-connected": "<span size='115%'>’Ŗō</span>  {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "interval": 30,
    "on-click": "~/.config/hypr/settings/bluetooth.sh"
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // Backlight
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ŅÄŹ",
      "ŅÅö",
      "ŅÅō",
      "ŅÅÆ",
      "ŅÅæ",
      "ŅÅÉ",
      "ŅÅÅ",
      "ŅÅÄ",
      "ŅÅŹ",
      "ŅÅī",
      "ŅÅŗ",
      "ŅÅŖ",
      "ŅÅē",
      "ŅÅł",
      "ŅÄø"
    ],
    "scroll-step": 1
  }
}
